# Uploads (user content)
uploads/submissions/*
!uploads/submissions/.gitkeep

# PHP error logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp

# Local Python virtual environment (dev-only)
.venv/

# Credentials — never commit, manage per-environment
config/database.php
config/secrets.php

# Seed data — contains real test data
sql/seed.php

# One-time setup script — never commit
setup_git.php

# Project context doc — internal, not for public repo
claude.md

# as it only triggers git pull (no shell injection possible)
