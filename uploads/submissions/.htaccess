# Apache configuration for Mission Token uploads folder
# Allow image files to be served directly; block all script execution

# Deny access to everything by default
<FilesMatch ".*">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow only safe image types
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# Block PHP and other script execution unconditionally
Options -ExecCGI
AddHandler cgi-script .php .php3 .php4 .php5 .phtml .pl .py .jsp .asp .htm .html .shtml

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
