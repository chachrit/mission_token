<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Only add webp — jpg/jpeg/png/gif already registered at IIS server level -->
    <!-- Adding duplicates or clearing handlers causes 500 on locked sections  -->
    <staticContent>
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>
  </system.webServer>
  <system.web>
    <!-- Allow anonymous access to uploaded files (avatars, submissions) -->
    <authorization>
      <allow users="?" />
    </authorization>
  </system.web>
</configuration>
